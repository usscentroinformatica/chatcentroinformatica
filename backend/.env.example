# Variables de entorno requeridas para el Chatbot USS

# API Key de Google Gemini (OBLIGATORIO)
GEMINI_API_KEY=tu_gemini_api_key_aqui

# Puerto del servidor (OPCIONAL - por defecto 5000)
PORT=5000

# Configuración de Google Sheets (OPCIONAL - para almacenar datos)
GOOGLE_SHEET_ID=tu_id_de_hoja_de_calculo_aqui
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-service-account@tu-proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntu_clave_privada_aqui\n-----END PRIVATE KEY-----\n"

# Instrucciones para configurar Google Sheets:
# 1. Ve a Google Cloud Console (https://console.cloud.google.com/)
# 2. Crea un nuevo proyecto o selecciona uno existente
# 3. Habilita la API de Google Sheets
# 4. Crea una Service Account en "IAM & Admin" > "Service Accounts"
# 5. Genera una clave JSON para la Service Account
# 6. Copia el email y la private key de la clave JSON
# 7. Crea una hoja de Google Sheets y compártela con el email de la Service Account
# 8. Copia el ID de la hoja desde la URL (la parte entre /d/ y /edit)